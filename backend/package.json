{
  "name": "task-manager-backend",
  "version": "1.0.0",
  "description": "DevOps Task Manager - Node.js/Express API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "NODE_ENV=test jest --coverage --forceExit --coverageThreshold='{\"global\":{\"lines\":70}}'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "routes/**/*.js",
      "!index.js"
    ]
  }
}
