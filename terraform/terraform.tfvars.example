# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!

do_token       = "your-digitalocean-api-token"
region         = "ams3"
cluster_name   = "task-manager-cluster"
k8s_version    = "1.31"
node_size      = "s-2vcpu-4gb"
min_node_count = 1
max_node_count = 3
